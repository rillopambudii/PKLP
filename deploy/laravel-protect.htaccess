# Upload file ini ke:  htdocs/laravel/.htaccess
# Tujuannya: BLOKIR akses publik ke seluruh file Laravel
# (mis. /laravel/.env, /laravel/config, dll) lewat browser.
# Request normal tetap masuk lewat htdocs/index.php.

# Apache 2.4
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2 (fallback)
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
