###############################################################
# .env untuk PRODUKSI (InfinityFree)
# Cara pakai:
#   1. Ganti nilai DB_* dengan data dari panel InfinityFree
#      (menu "MySQL Databases").
#   2. Ganti APP_URL dengan domain situsmu.
#   3. Upload file ini ke server, lalu RENAME jadi  .env
###############################################################

APP_NAME="PKLP Monitoring"
APP_ENV=production
APP_KEY=base64:yXJuiekXBYsKqQ3aNuon9Mgk66VcvA2uqZ1KqLqasAE=
APP_DEBUG=false
APP_URL=https://NAMA-SITUSMU.infinityfreeapp.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database: AMBIL dari panel InfinityFree → MySQL Databases ---
DB_CONNECTION=mysql
DB_HOST=sqlXXX.infinityfree.com
DB_PORT=3306
DB_DATABASE=if0_XXXXXXXX_pklp
DB_USERNAME=if0_XXXXXXXX
DB_PASSWORD=PASSWORD_DARI_PANEL

# Driver pakai database (tabelnya sudah ikut ter-import dari pklp_database.sql)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
